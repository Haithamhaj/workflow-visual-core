{
  "name": "workflow-visual-core",
  "version": "1.0.0",
  "description": "Portable visual graph library — converts WorkflowGraph JSON to Mermaid, React Flow, and more",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "ajv": "^8.13.0"
  },
  "dependencies": {
    "ajv": "^8.13.0"
  }
}
